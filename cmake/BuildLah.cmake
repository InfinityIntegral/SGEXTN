endfunction()

function(BuildLah_findDependencies)
    cmake_parse_arguments(ARG "" "LIBRARY" "COMPONENTS" ${ARGN})
    if(NOT ARG_LIBRARY)
        BuildLah_internal_nf_printFatalError("must specify library to find in BuildLah_findDependencies")
    endif()
    if(DEFINED ARG_UNPARSED_ARGUMENTS)
        BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_findDependencies, pls use named arguments")
    endif()
    BuildLah_internal_nf_printToGenericLog("looking for ${ARG_LIBRARY}... with following components:")
    BuildLah_internal_nf_printListToGenericLog("${ARG_COMPONENTS}")
    BuildLah_internal_nf_printToGenericLog("custom specified root of ${ARG_LIBRARY}: $ENV{${ARG_LIBRARY}_ROOT}")
    BuildLah_internal_nf_printToGenericLog("if finding the dependency fails, consider specifying ${ARG_LIBRARY}_ROOT as an environmental variable (not CMake variable) in whatever shell that you are running CMake from")
    find_package("${ARG_LIBRARY}" COMPONENTS ${ARG_COMPONENTS})
    if(NOT ${ARG_LIBRARY}_FOUND)
        BuildLah_internal_nf_printFatalError("failed to find ${ARG_LIBRARY}, try setting shell environmental variable ${ARG_LIBRARY}_ROOT")
    endif()
    if(NOT DEFINED ${ARG_LIBRARY}_CONFIG)
        BuildLah_internal_nf_printToGenericLog("${ARG_LIBRARY} is found using a 3rd party config file likely provided by CMake or the operating system")
    else()
        BuildLah_internal_nf_printToGenericLog("config file for ${ARG_LIBRARY} is found at: ${${ARG_LIBRARY}_CONFIG}")
    endif()
    BuildLah_internal_nf_printToGenericLog("")
endfunction()

function(BuildLah_addComponent)
    cmake_parse_arguments("ARG" "" "NAME;TYPE;ROOT_FOLDER" "DEPENDENCIES;EXTRA_FOLDERS;DEFINES;COMPILER_FLAGS;LINKER_FLAGS" ${ARGN})
    if(NOT ARG_NAME)
        BuildLah_internal_nf_printFatalError("must specify component name in BuildLah_addComponent")
    endif()
    if(NOT ARG_TYPE)
        BuildLah_internal_nf_printFatalError("must specify component type in BuildLah_addComponent")
    endif()
    if(NOT ARG_ROOT_FOLDER)
        BuildLah_internal_nf_printFatalError("must specify component root folder in BuildLah_addComponent, use . if the root folder is the one where CMakeLists.txt is")
    endif()
    if(DEFINED ARG_UNPARSED_ARGUMENTS)
        BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent, pls use named arguments")
    endif()
    if(DEFINED ARG_DEPENDENCIES)
        cmake_parse_arguments("ARG_DEP" "" "" "INTERNAL;FORWARD;FORWARD_ONLY" ${ARG_DEPENDENCIES})
        if(DEFINED ARG_DEP_UNPARSED_ARGUMENTS)
            BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent as dependencies, pls specify INTERNAL / FORWARD / FORWARD_ONLY")
        endif()
    endif()
    if(DEFINED ARG_EXTRA_FOLDERS)
        cmake_parse_arguments("ARG_EXF" "" "" "HEADER;SOURCE;ASSETS;SHADERS" ${ARG_EXTRA_FOLDERS})
        if(DEFINED ARG_EXF_UNPARSED_ARGUMENTS)
            BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent as extra folders, pls specify the type of extra folder to be added")
        endif()
    endif()
    if(DEFINED ARG_DEFINES)
        cmake_parse_arguments("ARG_DEF" "" "" "INTERNAL;FORWARD;FORWARD_ONLY" ${ARG_DEFINES})
        if(DEFINED ARG_DEF_UNPARSED_ARGUMENTS)
            BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent as preprocessor defines, pls specify INTERNAL / FORWARD / FORWARD_ONLY")
        endif()
    endif()
    if(DEFINED ARG_COMPILER_FLAGS)
        cmake_parse_arguments("ARG_CF" "" "" "INTERNAL;FORWARD;FORWARD_ONLY" ${ARG_COMPILER_FLAGS})
        if(DEFINED ARG_CF_UNPARSED_ARGUMENTS)
            BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent as compiler flags, pls specify INTERNAL / FORWARD / FORWARD_ONLY")
        endif()
    endif()
    if(DEFINED ARG_LINKER_FLAGS)
        cmake_parse_arguments("ARG_LF" "" "" "INTERNAL;FORWARD;FORWARD_ONLY" ${ARG_LINKER_FLAGS})
        if(DEFINED ARG_LF_UNPARSED_ARGUMENTS)
            BuildLah_internal_nf_printFatalError("unrecognised arguments received by BuildLah_addComponent as linker flags, pls specify INTERNAL / FORWARD / FORWARD_ONLY")
        endif()
    endif()

    if("${ARG_TYPE}" STREQUAL "LIBRARY")
        get_property(tempVar1 GLOBAL PROPERTY TARGET_SUPPORTS_SHARED_LIBS)
        if(tempVar1)
            add_library("${ARG_NAME}" SHARED)
            BuildLah_internal_nf_printToGenericLog("added ${ARG_NAME} as shared library")
            if(APPLE)
                set_property(TARGET "${ARG_NAME}" PROPERTY FRAMEWORK true)
                set_property(TARGET "${ARG_NAME}" PROPERTY FRAMEWORK_VERSION "A")
            endif()
        else()
            BuildLah_internal_nf_printToGenericLog("the platform currently being built for does not support use of shared libraries, using static library instead")
            add_library("${ARG_NAME}" STATIC)
            BuildLah_internal_nf_printToGenericLog("added ${ARG_NAME} as static library")
        endif()
        unset(tempVar1)
    elseif("${ARG_TYPE}" STREQUAL "GUI_APP")
        add_executable("${ARG_NAME}" WIN32 MACOSX_BUNDLE)
        BuildLah_internal_nf_printToGenericLog("added ${ARG_NAME} as GUI application")
    elseif("${ARG_TYPE}" STREQUAL "CLI_APP")
        add_executable("${ARG_NAME}")
        BuildLah_internal_nf_printToGenericLog("added ${ARG_NAME} as CLI application")
    else()
        BuildLah_internal_nf_printFatalError("${ARG_TYPE} is not a valid choice for the type of a component, use LIBRARY / GUI_APP / CLI_APP instead")
    endif()

    if("${ARG_TYPE}" STREQUAL "LIBRARY")
        set_property(TARGET "${ARG_NAME}" PROPERTY COMPILE_PDB_OUTPUT_DIRECTORY "lib")
        set_property(TARGET "${ARG_NAME}" PROPERTY PDB_OUTPUT_DIRECTORY "lib")
    else()
        set_property(TARGET "${ARG_NAME}" PROPERTY COMPILE_PDB_OUTPUT_DIRECTORY "bin")
        set_property(TARGET "${ARG_NAME}" PROPERTY PDB_OUTPUT_DIRECTORY "bin")
    endif()

    set_property(TARGET "${ARG_NAME}" PROPERTY NO_SONAME false)
    set_property(TARGET "${ARG_NAME}" PROPERTY MACHO_COMPATIBILITY_VERSION "${CMAKE_PROJECT_VERSION}")
    set_property(TARGET "${ARG_NAME}" PROPERTY MACHO_CURRENT_VERSION "${CMAKE_PROJECT_VERSION}")
    set_property(TARGET "${ARG_NAME}" PROPERTY SOVERSION "${CMAKE_PROJECT_VERSION}")
    set_property(TARGET "${ARG_NAME}" PROPERTY VERSION "${CMAKE_PROJECT_VERSION}")
    BuildLah_internal_nf_printToGenericLog("version number of ${ARG_NAME}: ${CMAKE_PROJECT_VERSION}")

    if(MSVC)
        target_compile_options("${ARG_NAME}" PRIVATE "/utf-8")
    else()
        target_compile_options("${ARG_NAME}" PRIVATE "-finput-charset=UTF-8")
        target_compile_options("${ARG_NAME}" PRIVATE "-fexec-charset=UTF-8")
    endif()
    BuildLah_internal_nf_printToGenericLog("set ${ARG_NAME} to interpret all string literals as UTF8 encoded")

    file(WRITE "${CMAKE_BINARY_DIR}/BuildLah_SharedLibrarySymbolExporting.h" "#pragma once\n\n#define BUILDLAH_INTERNAL_WindowsSharedLibrarySymbolExport __declspec(dllexport)\n#define BUILDLAH_INTERNAL_WindowsSharedLibrarySymbolImport __declspec(dllimport)\n#define BUILDLAH_INTERNAL_UnixSharedLibrarySymbolVisibility __attribute__((visibility(\"default\")))\n")
    if(MSVC)
        target_compile_options("${ARG_NAME}" PRIVATE /FI"${CMAKE_BINARY_DIR}/BuildLah_SharedLibrarySymbolExporting.h")
    else()
        target_compile_options("${ARG_NAME}" PRIVATE -include "${CMAKE_BINARY_DIR}/BuildLah_SharedLibrarySymbolExporting.h")
    endif()
    BuildLah_internal_nf_printToGenericLog("wrote BuildLah_SharedLibrarySymbolExporting.h in build folder for shared library symbol visibility macros")

    if(WIN32)
        target_compile_definitions("${ARG_NAME}" PRIVATE "BuildLah_${CMAKE_PROJECT_NAME}_${ARG_NAME}=BUILDLAH_INTERNAL_WindowsSharedLibrarySymbolExport")
        target_compile_definitions("${ARG_NAME}" INTERFACE "BuildLah_${CMAKE_PROJECT_NAME}_${ARG_NAME}=BUILDLAH_INTERNAL_WindowsSharedLibrarySymbolImport")
    elseif(UNIX)
        target_compile_definitions("${ARG_NAME}" PUBLIC "BuildLah_${CMAKE_PROJECT_NAME}_${ARG_NAME}=BUILDLAH_INTERNAL_UnixSharedLibrarySymbolVisibility")
    endif()
    BuildLah_internal_nf_printToGenericLog("BuildLah_${CMAKE_PROJECT_NAME}_${ARG_NAME} is defined to be the shared library symbol exporting indicator and can be placed in the definition of classes that should be exported")
    BuildLah_internal_nf_printToGenericLog("for example:")
    BuildLah_internal_nf_printToGenericLog("class BuildLah_${CMAKE_PROJECT_NAME}_${ARG_NAME} PublicExposedClass {};")
    BuildLah_internal_nf_printToGenericLog("")

    set(componentRoot "${CMAKE_SOURCE_DIR}/${ARG_ROOT_FOLDER}")
    if("${ARG_ROOT_FOLDER}" STREQUAL ".")
        set(componentRoot "${CMAKE_SOURCE_DIR}")
    endif()
    if(NOT IS_DIRECTORY "${componentRoot}")
        BuildLah_internal_nf_printFatalError("the root folder ${ARG_ROOT_FOLDER} of the component which resolves to ${componentRoot} is not actually a folder, pls use a path relative to the folder containing your CMakeLists.txt")
    endif()

    if(IS_DIRECTORY "${componentRoot}/include")
        list(APPEND ARG_EXF_HEADER "include")
    endif()
    if(IS_DIRECTORY "${componentRoot}/src")
        list(APPEND ARG_EXF_SOURCE "src")
    endif()
    if(IS_DIRECTORY "${componentRoot}/assets")
        list(APPEND ARG_EXF_ASSETS "assets")
    endif()
    if(IS_DIRECTORY "${componentRoot}/shaders")
        list(APPEND ARG_EXF_SHADERS "shaders")
    endif()

    set(tempVar1 "")
    set(tempVar2 "")
    set(tempVar3 "")
    set(tempVar4 "")
    set(tempVar5 "")
    set(tempVar6 "")
    set(tempVar7 "")
    set(tempVar8 "")
    set(tempVar9 "")
    unset(tempVar1)
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)
    unset(tempVar5)
    unset(tempVar6)
    unset(tempVar7)
    unset(tempVar8)
    unset(tempVar9)

    set(tempVar1 "")
    foreach(tempVar2 ${ARG_EXF_HEADER})
        if(NOT IS_DIRECTORY "${componentRoot}/${tempVar2}")
            BuildLah_internal_nf_printFatalError("header folder ${tempVar2} of component ${ARG_NAME} which resolves to ${componentRoot}/${tempVar2} does not exist")
        endif()
        target_include_directories("${ARG_NAME}" PUBLIC "$<BUILD_INTERFACE:${componentRoot}/${tempVar2}>")
        target_include_directories("${ARG_NAME}" PUBLIC "$<INSTALL_INTERFACE:include>")
        BuildLah_internal_nf_printToGenericLog("added ${tempVar2} as header folder of ${ARG_NAME}")
        file(GLOB_RECURSE tempVar3 CONFIGURE_DEPENDS "${componentRoot}/${tempVar2}/*.h")
        list(APPEND tempVar1 "${tempVar3}")
        foreach(tempVar4 ${tempVar3})
            string(REPLACE "${componentRoot}/" "" tempVar5 "${tempVar4}")
            BuildLah_internal_nf_printToGenericLog("- ${tempVar5}")
        endforeach()
    endforeach()
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)
    unset(tempVar5)

    foreach(tempVar2 ${tempVar1})
        get_filename_component(tempVar3 "${tempVar2}" NAME)
        string(FIND "${tempVar3}" "${CMAKE_PROJECT_NAME}_${ARG_NAME}_" tempVar4)
        if(NOT tempVar4 EQUAL 0)
            BuildLah_internal_nf_printWarning("consider renaming header file ${tempVar3} at path ${tempVar2} to start with ${CMAKE_PROJECT_NAME}_${ARG_NAME}_ to avoid header file name collision in #include directives because header file names cannot be namespaced")
        endif()
    endforeach()
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)
    BuildLah_internal_nf_printToGenericLog("")

    foreach(tempVar2 ${ARG_EXF_SOURCE})
        if(NOT IS_DIRECTORY "${componentRoot}/${tempVar2}")
            BuildLah_internal_nf_printFatalError("source folder ${tempVar2} of component ${ARG_NAME} which resolves to ${componentRoot}/${tempVar2} does not exist")
        endif()
        BuildLah_internal_nf_printToGenericLog("added ${tempVar2} as source folder of ${ARG_NAME}")
        file(GLOB_RECURSE tempVar3 CONFIGURE_DEPENDS "${componentRoot}/${tempVar2}/*.cpp")
        list(APPEND tempVar1 "${tempVar3}")
        foreach(tempVar4 ${tempVar3})
            target_sources("${ARG_NAME}" PRIVATE "${tempVar4}")
            string(REPLACE "${componentRoot}/" "" tempVar5 "${tempVar4}")
            BuildLah_internal_nf_printToGenericLog("- ${tempVar5}")
        endforeach()
    endforeach()
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)
    unset(tempVar5)

    set(tempVar5 "")
    foreach(tempVar2 ${tempVar1})
        string(REPLACE "${componentRoot}/" "" tempVar4 "${tempVar2}")
        set(tempVar3 "${CMAKE_BINARY_DIR}/BuildLah_licenseCheck/${tempVar4}.licensecheck")
        add_custom_command(
            OUTPUT "${tempVar3}"
            COMMAND "${CMAKE_COMMAND}" "-Did=${CMAKE_PROJECT_NAME} ${CMAKE_PROJECT_VERSION}" "-Dinput=${tempVar2}" "-Doutput=${tempVar3}" "-P" "${BuildLah_internal_v_installFolder}/BuildLah_CheckLicense.cmake"
            DEPENDS "${tempVar2}"
            COMMENT "${ARG_NAME} license check: ${tempVar4}"
            VERBATIM
        )
        list(APPEND tempVar5 "${tempVar3}")
    endforeach()
    add_custom_target("BuildLah_internal_t_${ARG_NAME}_licenseCheck" DEPENDS "${tempVar5}")
    add_dependencies("${ARG_NAME}" "BuildLah_internal_t_${ARG_NAME}_licenseCheck")
    unset(tempVar1)
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)
    unset(tempVar5)
    BuildLah_internal_nf_printToGenericLog("")

    # TODO: add SingEmbed for assets (ARG_EXF_ASSETS)
    # TODO: add SingEmbed for shaders (ARG_EXF_SHADERS)
    # TODO: add SingEmbed path collision check

    if(DEFINED ARG_DEP_INTERNAL)
        foreach(tempVar1 ${ARG_DEP_INTERNAL})
            if(NOT TARGET "${tempVar1}")
                BuildLah_internal_nf_printFatalError("internal dependency ${tempVar1} is not valid, ensure that you use BuildLah_findDependencies() to find it first")
            endif()
            target_link_libraries("${ARG_NAME}" PRIVATE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("linked library ${tempVar1} to ${ARG_NAME} as internal dependency")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_DEP_FORWARD)
        foreach(tempVar1 ${ARG_DEP_FORWARD})
            if(NOT TARGET "${tempVar1}")
                BuildLah_internal_nf_printFatalError("forward dependency ${tempVar1} is not valid, ensure that you use BuildLah_findDependencies() to find it first")
            endif()
            target_link_libraries("${ARG_NAME}" PUBLIC "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("linked library ${tempVar1} to ${ARG_NAME} as forward dependency")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_DEP_FORWARD_ONLY)
        foreach(tempVar1 ${ARG_DEP_FORWARD_ONLY})
            if(NOT TARGET "${tempVar1}")
                BuildLah_internal_nf_printFatalError("forward only dependency ${tempVar1} is not valid, ensure that you use BuildLah_findDependencies() to find it first")
            endif()
            target_link_libraries("${ARG_NAME}" INTERFACE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("linked library ${tempVar1} to ${ARG_NAME} as forward only dependency")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_DEF_INTERNAL)
        foreach(tempVar1 ${DEFINE_ARG_DEF_INTERNAL})
            target_compile_definitions("${ARG_NAME}" PRIVATE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added internal preprocessor define ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_DEF_FORWARD)
        foreach(tempVar1 ${DEFINE_ARG_DEF_FORWARD})
            target_compile_definitions("${ARG_NAME}" PUBLIC "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward preprocessor define ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_DEF_FORWARD_ONLY)
        foreach(tempVar1 ${DEFINE_ARG_DEF_FORWARD_ONLY})
            target_compile_definitions("${ARG_NAME}" INTERFACE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward only preprocessor define ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_CF_INTERNAL)
        foreach(tempVar1 ${ARG_CF_INTERNAL})
            target_compile_options("${ARG_NAME}" PRIVATE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added internal compile flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_CF_FORWARD)
        foreach(tempVar1 ${ARG_CF_FORWARD})
            target_compile_options("${ARG_NAME}" PUBLIC "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward compile flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_CF_FORWARD_ONLY)
        foreach(tempVar1 ${ARG_CF_FORWARD_ONLY})
            target_compile_options("${ARG_NAME}" INTERFACE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward only compile flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_LF_INTERNAL)
        foreach(tempVar1 ${ARG_LF_INTERNAL})
            target_link_options("${ARG_NAME}" PRIVATE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added internal linker flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_LF_FORWARD)
        foreach(tempVar1 ${ARG_LF_FORWARD})
            target_link_options("${ARG_NAME}" PUBLIC "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward linker flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)

    if(DEFINED ARG_LF_FORWARD_ONLY)
        foreach(tempVar1 ${ARG_LF_FORWARD_ONLY})
            target_link_options("${ARG_NAME}" INTERFACE "${tempVar1}")
            BuildLah_internal_nf_printToGenericLog("added forward only linker flag ${tempVar1} to ${ARG_NAME}")
        endforeach()
    endif()
    unset(tempVar1)
    BuildLah_internal_nf_printToGenericLog("")

    install( # for Linux only, other platforms will be added later
        TARGETS "${ARG_NAME}"
        EXPORT "${CMAKE_PROJECT_NAME}Targets"
        ARCHIVE DESTINATION "lib"
        LIBRARY DESTINATION "lib"
        RUNTIME DESTINATION "bin"
        FRAMEWORK DESTINATION "lib"
        BUNDLE DESTINATION "bin"
    )
    foreach(tempVar1 ${ARG_EXF_HEADER})
        install(DIRECTORY "${componentRoot}/${tempVar1}/" DESTINATION "include")
    endforeach()
    unset(tempVar1)
    BuildLah_internal_nf_printToGenericLog("installation rules added for ${ARG_NAME}")

    add_dependencies("${ARG_NAME}" "BuildLah_internal_t_finalisationCheck")
    BuildLah_internal_nf_printStatus("setup of ${ARG_NAME} done")
    BuildLah_internal_nf_printToGenericLog("")
endfunction()

function(BuildLah_finaliseProject)
    if(NOT ARGC EQUAL 0)
        BuildLah_internal_nf_printFatalError("BuildLah_finaliseProject does not take any arguments")
    endif()

    install(
        EXPORT "${CMAKE_PROJECT_NAME}Targets"
        DESTINATION "lib/cmake/${CMAKE_PROJECT_NAME}"
        NAMESPACE "${CMAKE_PROJECT_NAME}::"
    )
    include(CMakePackageConfigHelpers)
    configure_package_config_file("cmake/template.cmake.in" "${CMAKE_BINARY_DIR}/${CMAKE_PROJECT_NAME}Config.cmake" INSTALL_DESTINATION "lib/cmake/${CMAKE_PROJECT_NAME}")
    install(FILES "${CMAKE_BINARY_DIR}/${CMAKE_PROJECT_NAME}Config.cmake" DESTINATION "lib/cmake/${CMAKE_PROJECT_NAME}")
    if("${CMAKE_PROJECT_NAME}" STREQUAL "SGEXTN")
        install(FILES "cmake/BuildLah.cmake" DESTINATION "lib/cmake/SGEXTN")
        install(FILES "cmake/BuildLah_CheckLicense.cmake" DESTINATION "lib/cmake/SGEXTN")
        install(FILES "cmake/BuildLah_CheckFinalisation.cmake" DESTINATION "lib/cmake/SGEXTN")
    endif()
    BuildLah_internal_nf_printToGenericLog("done setting install rules for the whole project")

    get_property(tempVar1 DIRECTORY "${CMAKE_SOURCE_DIR}" PROPERTY BUILDSYSTEM_TARGETS)
    foreach(tempVar2 ${tempVar1})
        get_property(tempVar3 TARGET "${tempVar2}" PROPERTY NAME)
        get_property(tempVar4 TARGET "${tempVar2}" PROPERTY TYPE)
        if("${tempVar4}" STREQUAL "EXECUTABLE")
            BuildLah_internal_nf_printToFinalLog("executable ${tempVar3}:")
        elseif("${tempVar4}" STREQUAL "STATIC_LIBRARY")
            BuildLah_internal_nf_printToFinalLog("static library ${tempVar3}:")
        elseif("${tempVar4}" STREQUAL "SHARED_LIBRARY")
            BuildLah_internal_nf_printToFinalLog("shared library ${tempVar3}:")
        else()
            continue()
        endif()
        get_property(tempVar4 TARGET "${tempVar2}" PROPERTY VERSION)
        BuildLah_internal_nf_printToFinalLog("version: ${tempVar4}")
        get_property(tempVar4 TARGET "${tempVar2}" PROPERTY COMPILE_DEFINITIONS)
        BuildLah_internal_nf_printToFinalLog("preprocessor defines:")
        BuildLah_internal_nf_printListToFinalLog("${tempVar4}")
        get_property(tempVar4 TARGET "${tempVar2}" PROPERTY COMPILE_OPTIONS)
        BuildLah_internal_nf_printToFinalLog("compiler flags:")
        BuildLah_internal_nf_printListToFinalLog("${tempVar4}")
        get_property(tempVar4 TARGET "${tempVar2}" PROPERTY LINK_OPTIONS)
        BuildLah_internal_nf_printToFinalLog("linker flags:")
