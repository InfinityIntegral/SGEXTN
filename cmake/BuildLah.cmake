    BuildLah_internal_nf_printStatus("forwardDefines is a list of preprocessor defines enabled for both this component and the dependencies of this component, this is similar to using target_compile_definitions() with PUBLIC option")
    BuildLah_internal_nf_printStatus("forwardOnlyDefines is a list of preprocessor defines enabled for only the dependencies of this component but not this component. this is similar to using target_compile_definitions() with INTERFACE option")
    BuildLah_internal_nf_printStatus("internalCompilerFlags is a list of compiler flags enabled for this component but not the dependencies of this component, this is similar to using target_compile_options() with PRIVATE option")
    BuildLah_internal_nf_printStatus("forwardCompilerFlags is a list of compiler flags enabled for both this component and the dependencies of this component, this is similar to using target_compile_options() with PUBLIC option")
    BuildLah_internal_nf_printStatus("forwardOnlyCompilerFlags is a list of compiler flags enabled for only the dependencies of this component but not this component. this is similar to using target_compile_options() with INTERFACE option")
    BuildLah_internal_nf_printStatus("use generator expressions to write compiler flags as the syntax differs significantly between compilers")
    BuildLah_internal_nf_printStatus("internalLinkerFlags is a list of linker flags enabled for this component but not the dependencies of this component, this is similar to using target_link_options() with PRIVATE option")
    BuildLah_internal_nf_printStatus("forwardLinkerFlags is a list of linker flags enabled for both this component and the dependencies of this component, this is similar to using target_link_options() with PUBLIC option")
    BuildLah_internal_nf_printStatus("forwardOnlyLinkerFlags is a list of linker flags enabled for only the dependencies of this component but not this component. this is similar to using target_link_options() with INTERFACE option")
