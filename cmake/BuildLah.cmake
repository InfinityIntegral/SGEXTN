set(CMAKE_REQUIRED_QUIET true)
include(CheckTypeSize)
set(tempVar1 false)
check_type_size("short" BUILDLAH_SIZEOF_SHORT BUILTIN_TYPES_ONLY LANGUAGE CXX)
if(NOT BUILDLAH_SIZEOF_SHORT EQUAL 2)
    BuildLah_internal_nf_printWarning("sizeof(short) is ${BUILDLAH_SIZEOF_SHORT} instead of 2, this may cause issues")
    set(tempVar1 true)
endif()
check_type_size("int" BUILDLAH_SIZEOF_INT BUILTIN_TYPES_ONLY LANGUAGE CXX)
if(NOT BUILDLAH_SIZEOF_INT EQUAL 4)
    BuildLah_internal_nf_printWarning("sizeof(int) is ${BUILDLAH_SIZEOF_INT} instead of 4, this may cause issues")
    set(tempVar1 true)
endif()
check_type_size("long long" BUILDLAH_SIZEOF_LONG_LONG BUILTIN_TYPES_ONLY LANGUAGE CXX)
if(NOT BUILDLAH_SIZEOF_LONG_LONG EQUAL 8)
    BuildLah_internal_nf_printWarning("sizeof(long long) is ${BUILDLAH_SIZEOF_LONG_LONG} instead of 8, this may cause issues")
    set(tempVar1 true)
endif()
check_type_size("float" BUILDLAH_SIZEOF_FLOAT BUILTIN_TYPES_ONLY LANGUAGE CXX)
if(NOT BUILDLAH_SIZEOF_FLOAT EQUAL 4)
    BuildLah_internal_nf_printWarning("sizeof(float) is ${BUILDLAH_SIZEOF_FLOAT} instead of 4, this may cause issues")
    set(tempVar1 true)
endif()
check_type_size("double" BUILDLAH_SIZEOF_DOUBLE BUILTIN_TYPES_ONLY LANGUAGE CXX)
if(NOT BUILDLAH_SIZEOF_DOUBLE EQUAL 8)
    BuildLah_internal_nf_printWarning("sizeof(double) is ${BUILDLAH_SIZEOF_DOUBLE} instead of 8, this may cause issues")
    set(tempVar1 true)
endif()
set(CMAKE_REQUIRED_QUIET false)
if(NOT tempVar1)
    BuildLah_internal_nf_printToGenericLog("size of short, int, long long, float, double, all match expectations")
endif()
unset(tempVar1)
BuildLah_internal_nf_printToGenericLog("")

