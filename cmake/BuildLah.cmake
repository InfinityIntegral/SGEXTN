function(BuildLah_help)
    BuildLah_internal_nf_printStatus("list of all BuildLah functions and how to use them:")
    BuildLah_internal_nf_printStatus("")
    BuildLah_internal_nf_printStatus("BuildLah_findDependencies:")
    BuildLah_internal_nf_printStatus("BuildLah_findDependencies(LIBRARY <libraryName> [COMPONENTS <componentNames>...])")
    BuildLah_internal_nf_printStatus("looks for a dependency with the name libraryName, specifying that only its components listed as part of componentNames are wanted")
    BuildLah_internal_nf_printStatus("this is similar to find_package(libraryName REQUIRED COMPONENTS componentNames)")
    BuildLah_internal_nf_printStatus("call this multiple times if you want multiple dependencies")
    BuildLah_internal_nf_printStatus("example usage: BuildLah_findDependencies(LIBRARY SGEXTN COMPONENTS Containers Math CoreText)")
    BuildLah_internal_nf_printStatus("the example attempts to find SGEXTN::Containers, SGEXTN::Math, SGEXTN::CoreText")
    BuildLah_internal_nf_printStatus("")
    BuildLah_internal_nf_printStatus("BuildLah_finaliseProject:")
    BuildLah_internal_nf_printStatus("BuildLah_finaliseProject()")
    BuildLah_internal_nf_printStatus("this must be called exactly once at the end of the CMakeLists.txt")
    BuildLah_internal_nf_printStatus("")
    BuildLah_internal_nf_printStatus("BuildLah_addComponent:")
    BuildLah_internal_nf_printStatus("BuildLah_addComponent(")
    BuildLah_internal_nf_printStatus("NAME <componentName>")
    BuildLah_internal_nf_printStatus("TYPE <componentType>")
    BuildLah_internal_nf_printStatus("ROOT_FOLDER <componentRootFolder>")
    BuildLah_internal_nf_printStatus("[DEPENDENCIES [INTERNAL <internalDependencies>...] [FORWARD <forwardDependencies>...] [FORWARD_ONLY <forwardOnlyDependencies>...]]")
    BuildLah_internal_nf_printStatus("[EXTRA_FOLDERS [HEADER <extraHeaderFolders>...] [SOURCE <extraSourceFolders>...] [ASSETS <extraAssetFolders>...] [SHADERS <extraShaderFolders>...]]")
    BuildLah_internal_nf_printStatus("[DEFINES [INTERNAL <internalDefines>...] [FORWARD <forwardDefines>...] [FORWARD_ONLY <forwardOnlyDefines>...]]")
    BuildLah_internal_nf_printStatus("[COMPILER_FLAGS [INTERNAL <internalCompilerFlags>...] [FORWARD <forwardCompilerFlags>...] [FORWARD_ONLY <forwardOnlyCompilerFlags>...]]")
    BuildLah_internal_nf_printStatus("[LINKER_FLAGS [INTERNAL <internalLinkerFlags>...] [FORWARD <forwardLinkerFlags>...] [FORWARD_ONLY <forwardOnlyLinkerFlags>...]]")
    BuildLah_internal_nf_printStatus(")")
    BuildLah_internal_nf_printStatus("adds a component to the project")
    BuildLah_internal_nf_printStatus("the name of the component, which is the CMake target name, is componentName")
    BuildLah_internal_nf_printStatus("the type of the component depends on componentType")
    BuildLah_internal_nf_printStatus("if componentType is LIBRARY, the component will be built as a shared library if the platform supports shared libraries, and as a static library otherwise")
    BuildLah_internal_nf_printStatus("if componentType is CLI_APP, the component will be built as a command line application which does not show a GUI window")
    BuildLah_internal_nf_printStatus("if componentType is GUI_APP, the component will be built as a GUI app")
    BuildLah_internal_nf_printStatus("the type of the component should match what it would be on Linux, for example a Android app should technically be build using add_library() in classic CMake but it counts as GUI_APP in BuildLah")
    BuildLah_internal_nf_printStatus("componentRootFolder is used as the root folder of the component, hereafter referred to as (root), this should be relative to where your CMakeLists.txt is located")
    BuildLah_internal_nf_printStatus("if the CMakeLists.txt is inside your component root folder, pass . as ROOT_FOLDER")
    BuildLah_internal_nf_printStatus("always specify folders with forward slash as separator and without leading or trailing slashes regardless of platform, this applies to all arguments of this command")
    BuildLah_internal_nf_printStatus("all folders in (root)/include in addition to everything listed in extraHeaderFolders are automatically counted as header folders, this is similar to target_include_directories() with PUBLIC option")
    BuildLah_internal_nf_printStatus("header folders are always forwarded to dependencies of this component, place private headers in a folder (root)/include/private_api instead of restricting them at the CMake level")
    BuildLah_internal_nf_printStatus("all .cpp files in (root)/src in addition to all .cpp files in all folders listed in extraSourceFolders are automatically added as source files, this is similar to target_sources() with PRIVATE option")
    BuildLah_internal_nf_printStatus("all files in (root)/assets in addition to all files in all folders listed in extraAssetFolders are automatically added to the SingEmbed system under the path 💖/projectName/componentName/fileName")
    BuildLah_internal_nf_printStatus("for example, in a project MyApp with component MyComponent having icon.png in its (root)/assets, the file icon.png could be accessed in SingEmbed via the path 💖/MyApp/MyComponent/icon.png")
    BuildLah_internal_nf_printStatus("if you want to keep something in the project folder without adding it to SingEmbed, place it in (root)/misc")
    BuildLah_internal_nf_printStatus("all files in (root)/shaders in addition to all files in all folders listed in extraShaderFolders are compiled and automatically added to the SingEmbed system under the path 💖/projectName/componentName/fileName.sgs")
    BuildLah_internal_nf_printStatus("Note that .sgs, SGEXTN Shader file, is a cross platform shader binary format conceptually similar but technically different and independent from Qt's .qsb")
    BuildLah_internal_nf_printStatus("for example, in a project MyApp with component MyComponent having shader.vert in its (root)/assets, the shader would be compiled and it could be accessed in SingEmbed via the path 💖/MyApp/MyComponent/shader.vert.sgs")
    BuildLah_internal_nf_printStatus("extra folders must all be located within (root) and have their paths specified relative to (root)")
    BuildLah_internal_nf_printStatus("internalDependencies is a list of libraries that this component links to but dependencies of this component do not link to, this is equivalent to target_link_libraries() with PRIVATE option")
    BuildLah_internal_nf_printStatus("forwardDependencies is a list of libraries that both this component and dependencies of this component link to, this is equivalent to target_link_libraries() with PUBLIC option")
    BuildLah_internal_nf_printStatus("forwardOnlyDependencies is a list of libraries that only dependencies of this component but not this component link to, this is equivalent to target_link_lbraries() with INTERFACE option")
