        BuildLah_internal_nf_printToFinalLog("")
    endforeach()
    unset(tempVar1)
    unset(tempVar2)
    unset(tempVar3)
    unset(tempVar4)

    file(REMOVE "${CMAKE_BINARY_DIR}/BuildLah_neverFinalise.sg")
    BuildLah_internal_nf_printStatus("project ${CMAKE_PROJECT_NAME} finalised")
    BuildLah_internal_nf_printStatus("")
endfunction()

