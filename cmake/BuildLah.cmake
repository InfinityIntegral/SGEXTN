function(BuildLah_internal_nf_printToFile)
    if(NOT ARGC EQUAL 2)
        message(FATAL_ERROR "can only print exactly 1 thing to exactly 1 file")
    endif()
    file(APPEND "${CMAKE_BINARY_DIR}/BuildLah_logs/${ARGV0}.txt" "${ARGV1}\n")
endfunction()

function(BuildLah_internal_nf_printToGenericLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing to generic log")
    endif()
    BuildLah_internal_nf_printToFile("generic_log" "${ARGV0}")
endfunction()

function(BuildLah_internal_nf_printListToGenericLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 list to generic log, pls quote lists")
    endif()
    set(RECEIVED_LIST "${ARGV0}")
    string(REPLACE ";" ", " RECEIVED_LIST "${RECEIVED_LIST}")
    set(RECEIVED_LIST "[${RECEIVED_LIST}]")
    BuildLah_internal_nf_printToGenericLog("${RECEIVED_LIST}")
endfunction()

function(BuildLah_internal_nf_printToPlatformInfoLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing to platform info log")
    endif()
    BuildLah_internal_nf_printToFile("generic_log" "${ARGV0}")
    BuildLah_internal_nf_printToFile("platform_info_log" "${ARGV0}")
endfunction()

function(BuildLah_internal_nf_printToFinalLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing to final log")
    endif()
    BuildLah_internal_nf_printToFile("generic_log" "${ARGV0}")
    BuildLah_internal_nf_printToFile("final_log" "${ARGV0}")
endfunction()

function(BuildLah_internal_nf_printListToFinalLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 list to final log, pls quote lists")
    endif()
    set(RECEIVED_LIST "${ARGV0}")
    string(REPLACE ";" ", " RECEIVED_LIST "${RECEIVED_LIST}")
    set(RECEIVED_LIST "[${RECEIVED_LIST}]")
    BuildLah_internal_nf_printToFinalLog("${RECEIVED_LIST}")
endfunction()

function(BuildLah_internal_nf_printLongListToFinalLog)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 list to final log, pls quote lists")
    endif()
    set(RECEIVED_LIST "")
    foreach(ELEMENT ${ARGV0})
        set(RECEIVED_LIST "${RECEIVED_LIST}- ${ELEMENT}\n")
    endforeach()
    BuildLah_internal_nf_printToFinalLog("${RECEIVED_LIST}")
endfunction()

function(BuildLah_internal_nf_printStatus)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing as status message")
    endif()
    BuildLah_internal_nf_printToGenericLog("${ARGV0}")
    message(STATUS "${ARGV0}")
endfunction()

function(BuildLah_internal_nf_printWarning)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing as warning message")
    endif()
    BuildLah_internal_nf_printToGenericLog("${ARGV0}")
    message(WARNING "${ARGV0}")
endfunction()

function(BuildLah_internal_nf_printFatalError)
    if(NOT ARGC EQUAL 1)
        message(FATAL_ERROR "can only print exactly 1 thing as fatal error message")
    endif()
    BuildLah_internal_nf_printToGenericLog("${ARGV0}")
    message(FATAL_ERROR "${ARGV0}")
endfunction()

